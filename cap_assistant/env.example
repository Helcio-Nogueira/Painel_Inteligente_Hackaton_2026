# Copie para .env e preencha se quiser respostas do modelo (opcional em modo demonstração).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# GROQ_API_KEY=

# Porta da API (predefinição 8765 — evita conflito com outros projetos na 8000)
# APP_PORT=8765

# Dataset de folha (predefinição: data/payroll.csv nesta pasta)
# PAYROLL_DATA_PATH=

# Busca web heurística (predefinição: desligada)
WEB_SEARCH_ENABLED=false
